# ==============================================================================
# SPENDLY - ENV CONFIGURATION EXAMPLE
# Copy this file to a real '.env' file in the server/ directory
# ==============================================================================

# Backend Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_passphrase_here

# MongoDB Database Connection
# Replace with local MongoDB or MongoDB Atlas URI
MONGODB_URI=mongodb://localhost:27017/spendly

# Email (SMTP) Configuration for OTP Deliveries
# If SMTP configurations are omitted, OTP codes will be printed to the Server console
# in development mode, allowing you to bypass setting up an email service.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
